region       = "us-east-1"
cluster_name = "eks-lab"

# Identidade compartilhada da suite para VPC e bucket S3. Se omitido, usa cluster_name.
# shared_infra_name = "eks-lab"

# Informe uma versao suportada pelo seu laboratorio/EKS.
kubernetes_version = "1.35"

# Roles IAM preexistentes para o EKS no laboratorio.
eks_cluster_role_arn = "arn:aws:iam::415459106622:role/c207442a5275926l14475550t1w415459-LabEksClusterRole-ZJrT0UsVDXGR"
eks_node_role_arn    = "arn:aws:iam::415459106622:role/c207442a5275926l14475550t1w415459106-LabEksNodeRole-o7WajVdYdjUf"

# Opcional. Se omitido ou removido, o root module usa o default do laboratorio.
eks_access_principal_arn = "arn:aws:iam::415459106622:role/voclabs"

instance_type = "t3.medium"
desired_size  = 1
min_size      = 1
max_size      = 2

cluster_endpoint_public_access_cidrs = ["0.0.0.0/0"]

# Por default, se o oficina-infra-db tiver subido antes, este projeto reutiliza
# a VPC compartilhada quando encontra o SG do RDS e nao encontra sinais de um EKS
# ja existente na mesma rede.
reuse_database_network = true
database_identifier    = "oficina-postgres-lab"

# Rede criada automaticamente quando nao houver rede reutilizavel.
# create_network_if_missing = true
# network_vpc_cidr          = "10.0.0.0/16"
# public_subnet_cidrs       = ["10.0.0.0/20", "10.0.16.0/20"]

# Opcional. Forca uma rede especifica e desativa a criacao automatica de VPC.
# vpc_id = "vpc-xxxxxxxx"
# public_subnet_ids = [
#   "subnet-aaaaaaaa",
#   "subnet-bbbbbbbb",
# ]

# O bucket S3 de dados compartilhados e criado por default.
# Se quiser um nome fixo, descomente a linha abaixo.
# terraform_shared_data_bucket_name = "tf-shared-eks-lab-<account-id>-us-east-1"

# O API Gateway HTTP API e criado por default, mas pode ficar sem rotas
# ate que a aplicacao principal e/ou os Lambdas existam.
#
# Por default, o ambiente lab publica o oficina-app na raiz do HTTP API:
# - ANY /
# - ANY /{proxy+}
#
# Essa publicacao usa VPC_LINK, NLB interno e o NodePort 30080 do Service
# Kubernetes oficina-app. Para desativar essa rota padrao:
# expose_oficina_app_api_gateway = false
#
# Para exigir JWT nativo do HTTP API nas rotas da aplicacao:
# oficina_app_api_gateway_jwt_authorizer_enabled = true
# oficina_app_api_gateway_jwt_issuer            = null # usa o endpoint publico do proprio HTTP API
# oficina_app_api_gateway_jwt_audience          = ["oficina-app"]
# oficina_app_api_gateway_jwt_scopes            = ["oficina-app"]
#
# Quando a flag estiver ativa, o gateway protege tudo por default e deixa
# publicos apenas:
# - /q/swagger-ui/
# - /q/swagger-ui/*
# - /q/health/live
# - /q/health/ready
# - /ordem-de-servico/{id}/acompanhar-link
# - /ordem-de-servico/{id}/aprovar-link
# - /ordem-de-servico/{id}/recusar-link
#
# O SMTP do MailHog tambem e exposto por default em um NLB interno, usando
# o NodePort 31025 do Service mailhog-smtp-private e um SG dedicado para a
# notificacao-lambda. Para desativar esse acesso privado:
# expose_mailhog_smtp_private_nlb = false
#
# Observabilidade AWS-native do lab:
# observability_enabled                      = true
# observability_enable_dashboard             = true
# observability_enable_route53_healthchecks  = true
# observability_enable_k8s_resource_metrics  = true
# observability_manage_node_role_policy_attachment = true
# observability_alert_email_endpoints        = ["ops@example.com"]
#
# Exemplo para publicar a aplicacao principal por URL publica:
# api_gateway_http_routes = {
#   "ANY /app" = {
#     integration_uri = "https://app-lab.exemplo.edu.br/app"
#   }
#   "ANY /app/{proxy+}" = {
#     integration_uri = "https://app-lab.exemplo.edu.br/app/{proxy}"
#   }
# }
#
# Exemplo para publicar um Lambda:
# api_gateway_lambda_routes = {
#   "POST /payments" = {
#     invoke_arn    = "arn:aws:lambda:us-east-1:415459106622:function:payments:live"
#     function_name = "arn:aws:lambda:us-east-1:415459106622:function:payments:live"
#   }
# }
